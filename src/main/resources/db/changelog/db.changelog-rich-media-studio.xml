<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

    <changeSet id="add-course-source-topic" author="antigravity">
        <addColumn tableName="courses">
            <column name="source" type="VARCHAR(255)" defaultValue="ai"/>
            <column name="topic" type="TEXT"/>
        </addColumn>
    </changeSet>

    <changeSet id="add-lesson-content-md" author="antigravity">
        <addColumn tableName="lessons">
            <column name="content_md" type="TEXT"/>
            <column name="estimated_minutes" type="INT"/>
        </addColumn>
    </changeSet>

    <changeSet id="add-lesson-is-enriched" author="antigravity">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="lessons" columnName="is_enriched"/>
            </not>
        </preConditions>
        <addColumn tableName="lessons">
            <column name="is_enriched" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>

    <changeSet id="create-lesson-media-table" author="antigravity">
        <createTable tableName="lesson_media">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="pk_lesson_media" nullable="false"/>
            </column>
            <column name="lesson_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="url" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="source" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="prompt" type="TEXT"/>
            <column name="alt" type="TEXT"/>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueDate="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="lesson_media"
                baseColumnNames="lesson_id"
                constraintName="fk_lesson_media_lesson"
                referencedTableName="lessons"
                referencedColumnNames="id"
                onDelete="CASCADE"/>
    </changeSet>

    <changeSet id="create-lesson-progress-table" author="antigravity">
        <validCheckSum>ANY</validCheckSum>
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="lesson_progress"/>
            </not>
        </preConditions>
        <createTable tableName="lesson_progress">
            <column name="user_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="lesson_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="completed_at" type="TIMESTAMP WITH TIME ZONE" defaultValueDate="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addPrimaryKey
                tableName="lesson_progress"
                columnNames="user_id, lesson_id"
                constraintName="pk_lesson_progress"/>

        <addForeignKeyConstraint
                baseTableName="lesson_progress"
                baseColumnNames="lesson_id"
                constraintName="fk_lesson_progress_lesson"
                referencedTableName="lessons"
                referencedColumnNames="id"
                onDelete="CASCADE"/>
        
        <addForeignKeyConstraint
                baseTableName="lesson_progress"
                baseColumnNames="user_id"
                constraintName="fk_lesson_progress_user"
                referencedTableName="users"
                referencedColumnNames="id"
                onDelete="CASCADE"/>
    </changeSet>
</databaseChangeLog>
