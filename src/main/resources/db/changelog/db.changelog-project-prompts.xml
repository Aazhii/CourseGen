<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

    <changeSet id="project-prompts-table" author="ari">
        <createTable tableName="project_prompts">
            <column name="id" type="VARCHAR(255)">
                <constraints primaryKey="true"
                             primaryKeyName="pk_project_prompts"
                             nullable="false"/>
            </column>

            <column name="project_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>

            <column name="text" type="TEXT">
                <constraints nullable="false"/>
            </column>

            <column name="related_course_id" type="VARCHAR(255)"/>
            <column name="related_course_title" type="VARCHAR(255)"/>

            <column name="created_at" type="TIMESTAMP WITH TIME ZONE"
                    defaultValueDate="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>

            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE"
                    defaultValueDate="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>

            <column name="last_used_at" type="TIMESTAMP WITH TIME ZONE"/>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="project_prompts"
                baseColumnNames="project_id"
                constraintName="fk_project_prompts_project"
                referencedTableName="projects"
                referencedColumnNames="id"
                onDelete="CASCADE"/>

        <createIndex indexName="idx_project_prompts_project_id"
                     tableName="project_prompts">
            <column name="project_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
