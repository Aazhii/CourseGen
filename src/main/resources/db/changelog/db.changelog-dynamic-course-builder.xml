<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

    <changeSet id="dynamic-course-builder-columns" author="antigravity">
        <!-- Keep prior checksum compatibility while replacing DB-version-specific SQL with safe guarded changeSets below. -->
        <validCheckSum>ANY</validCheckSum>
        <sql>SELECT 1</sql>
    </changeSet>

    <changeSet id="dynamic-course-builder-courses-category" author="antigravity">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="courses" columnName="category"/>
            </not>
        </preConditions>
        <addColumn tableName="courses">
            <column name="category" type="VARCHAR(255)"/>
        </addColumn>
    </changeSet>

